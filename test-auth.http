# Résultat attendu: 409 Conflict
# Note: Relancer cette requête 1.1 d'abord pour générer le conflit
POST {{BASE_URL}}/api/auth/register
Content-Type: application/json

{
  "nom": "Autre Utilisateur",
  "email": "{{EMAIL_TEST}}",
  "motDePasse": "Password123!",
  "confirmationMotDePasse": "Password123!",
  "role": "TRESORIER"
}

###############################################################################
# 2. TEST DE CONNEXION - LOGIN
###############################################################################

### 2.1 Connexion réussie - Trésorier
# Description: Connexion avec identifiants valides
# Résultat attendu: 200 OK + Token JWT
# Processus:
# 1. Recherche l'utilisateur par email
# 2. Vérifie que l'utilisateur est actif
# 3. Compare le mot de passe avec bcrypt
# 4. Génère un token JWT
# 5. Enregistre l'action dans l'audit
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "{{EMAIL_TEST}}",
  "motDePasse": "{{PASSWORD}}"
}

### 2.2 Connexion réussie - Admin
# Description: Connexion admin
# Résultat attendu: 200 OK + Token JWT
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@eglise.com",
  "motDePasse": "AdminSecure2026!"
}

### 2.3 Connexion réussie - Responsable
# Description: Connexion responsable
# Résultat attendu: 200 OK + Token JWT
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "responsable@eglise.com",
  "motDePasse": "ResponsablePass2026!"
}

### 2.4 Connexion réussie - Auditeur
# Description: Connexion auditeur
# Résultat attendu: 200 OK + Token JWT
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "auditeur@eglise.com",
  "motDePasse": "AuditeurPass2026!"
}

### 2.5 Connexion échouée - Email manquant
# Description: Tentative de connexion sans email
# Résultat attendu: 400 Bad Request
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "motDePasse": "{{PASSWORD}}"
}

### 2.6 Connexion échouée - Mot de passe manquant
# Description: Tentative de connexion sans mot de passe
# Résultat attendu: 400 Bad Request
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "{{EMAIL_TEST}}"
}

### 2.7 Connexion échouée - Email inexistant
# Description: Tentative de connexion avec email inexistant
# Résultat attendu: 401 Unauthorized
# Message: "Email ou mot de passe incorrect"
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "inexistant@eglise.com",
  "motDePasse": "{{PASSWORD}}"
}

### 2.8 Connexion échouée - Mot de passe incorrect
# Description: Tentative de connexion avec mauvais mot de passe
# Résultat attendu: 401 Unauthorized
# Message: "Email ou mot de passe incorrect"
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "{{EMAIL_TEST}}",
  "motDePasse": "MauvaisPassword123!"
}

###############################################################################
# 3. TEST DE DÉCONNEXION - LOGOUT
###############################################################################

### 3.1 Déconnexion réussie
# Description: Déconnexion avec token valide
# Résultat attendu: 200 OK
# Processus:
# 1. Valide le token JWT
# 2. Extrait les informations de l'utilisateur
# 3. Enregistre la déconnexion dans l'audit
# 4. Retourne un message de confirmation
# Note: Copier le token de 2.1 ou 2.2 et le mettre dans la variable {{TOKEN}}
POST {{BASE_URL}}/api/auth/logout
Content-Type: application/json
# Authorization: Bearer {{TOKEN}}

{}

### 3.2 Déconnexion échouée - Token manquant
# Description: Tentative de déconnexion sans token
# Résultat attendu: 401 Unauthorized
# Message: "Token manquant"
POST {{BASE_URL}}/api/auth/logout
Content-Type: application/json

{}

### 3.3 Déconnexion échouée - Token invalide
# Description: Tentative de déconnexion avec token faux
# Résultat attendu: 401 Unauthorized
# Message: "Token invalide ou expiré"
POST {{BASE_URL}}/api/auth/logout
Content-Type: application/json
Authorization: Bearer invalid.token.here

{}

### 3.4 Déconnexion échouée - Format Authorization invalide
# Description: Tentative sans "Bearer " en préfixe
# Résultat attendu: 401 Unauthorized
# Message: "Format Authorization invalide"
POST {{BASE_URL}}/api/auth/logout
Content-Type: application/json
# Authorization: {{TOKEN}}

{}

###############################################################################
# 4. SCÉNARIOS D'INTÉGRATION COMPLETS
###############################################################################

### 4.1 Scénario complet: Inscription �� Connexion → Déconnexion
# Instructions:
# 1. Exécuter 1.1 (Inscription)
# 2. Copier le token reçu et définir {{TOKEN}}
# 3. Exécuter 2.1 (Connexion) - devrait réussir
# 4. Copier le nouveau token et mettre à jour {{TOKEN}}
# 5. Exécuter 3.1 (Déconnexion)
# Résultat attendu: Tous les appels réussissent

###############################################################################
# 5. TESTS DE SÉCURITÉ
###############################################################################

### 5.1 Test brute-force - Plusieurs tentatives échouées
# Description: Simuler une tentative de brute-force
# Résultat attendu: 401 Unauthorized (à chaque fois)
# Note: La vraie protection serait d'ajouter un système de rate-limiting
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "{{EMAIL_TEST}}",
  "motDePasse": "MauvaisMotDePasse1"
}

### 5.2 Test brute-force - Deuxième tentative
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "{{EMAIL_TEST}}",
  "motDePasse": "MauvaisMotDePasse2"
}

### 5.3 Test brute-force - Troisième tentative
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "{{EMAIL_TEST}}",
  "motDePasse": "MauvaisMotDePasse3"
}

###############################################################################
# 6. TESTS DE VALIDATION DE DONNÉES
###############################################################################

### 6.1 Injection SQL - Email suspecte
# Description: Tentative d'injection SQL
# Résultat attendu: Validation correcte (aucune injection)
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
  "email": "test@eglise.com'; DROP TABLE utilisateurs; --",
  "motDePasse": "{{PASSWORD}}"
}

### 6.2 XSS - Contenu JavaScript dans le nom
# Description: Tentative de XSS dans l'inscription
# Résultat attendu: Stocké comme texte simple (pas d'exécution)
POST {{BASE_URL}}/api/auth/register
Content-Type: application/json

{
  "nom": "<script>alert('XSS')</script>",
  "email": "xss.test@eglise.com",
  "motDePasse": "Password123!",
  "confirmationMotDePasse": "Password123!",
  "role": "TRESORIER"
}

###############################################################################
# NOTES IMPORTANTES
###############################################################################

# 1. GESTION DU TOKEN
#    - Le token JWT est valide 24 heures
#    - À chaque connexion, un nouveau token est généré
#    - Le token contient: userId, email, role
#    - Ne JAMAIS exposer le token en production
#
# 2. SÉCURITÉ DES MOTS DE PASSE
#    - Minimum 8 caractères
#    - Hashés avec bcrypt (10 rounds)
#    - Jamais stockés en clair
#    - Jamais retournés au client
#
# 3. AUDIT ET LOGGING
#    - Chaque login/logout est enregistré
#    - Les erreurs d'authentification sont loggées
#    - Adresse IP et timestamp sont enregistrés
#
# 4. ERREURS INTENTIONNELLES
#    - Les messages d'erreur sont volontairement génériques
#    - "Email ou mot de passe incorrect" ne dit pas lequel est faux
#    - Cela prévient les attaques de énumération
#
# 5. PROCHAINES ÉTAPES
#    - Ajouter un système de rate-limiting
#    - Ajouter un système de 2FA (authentification à deux facteurs)
#    - Ajouter une fonction "Oublié mon mot de passe"
#    - Ajouter une confirmation d'email
#
###############################################################################