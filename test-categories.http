###############################################################################
# TESTS - MODULE CATEGORIES
#
# Plateforme de comptabilite pour l'Eglise du Christianisme Celeste
# Module: Categories (CRUD + filtres + droits)
#
# Utilisation Thunder Client / REST Client:
# 1. Lancer l'app: npm run dev
# 2. Executer les logins pour recuperer les tokens
# 3. Renseigner manuellement les variables TOKEN si necessaire
# 4. Executer les requetes dans l'ordre propose
###############################################################################

###############################################################################
# CONFIGURATION
###############################################################################

@BASE_URL = http://localhost:3000

@ADMIN_EMAIL = admin@eglise.com
@ADMIN_PASSWORD = AdminSecure2026!

@RESPONSABLE_EMAIL = responsable@eglise.com
@RESPONSABLE_PASSWORD = ResponsablePass2026!

@TRESORIER_EMAIL = tresorier.test@eglise.com
@TRESORIER_PASSWORD = SecurePassword123!

@AUDITEUR_EMAIL = auditeur@eglise.com
@AUDITEUR_PASSWORD = AuditeurPass2026!

# Collez ici les tokens retournes par les requetes de login.
@ADMIN_TOKEN = REMPLACER_PAR_TOKEN_ADMIN
@RESPONSABLE_TOKEN = REMPLACER_PAR_TOKEN_RESPONSABLE
@TRESORIER_TOKEN = REMPLACER_PAR_TOKEN_TRESORIER
@AUDITEUR_TOKEN = REMPLACER_PAR_TOKEN_AUDITEUR

###############################################################################
# 0. LOGIN - RECUPERER LES TOKENS
###############################################################################

### 0.1 Login Admin
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
	"email": "{{ADMIN_EMAIL}}",
	"motDePasse": "{{ADMIN_PASSWORD}}"
}

### 0.2 Login Responsable
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
	"email": "{{RESPONSABLE_EMAIL}}",
	"motDePasse": "{{RESPONSABLE_PASSWORD}}"
}

### 0.3 Login Tresorier
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
	"email": "{{TRESORIER_EMAIL}}",
	"motDePasse": "{{TRESORIER_PASSWORD}}"
}

### 0.4 Login Auditeur
POST {{BASE_URL}}/api/auth/login
Content-Type: application/json

{
	"email": "{{AUDITEUR_EMAIL}}",
	"motDePasse": "{{AUDITEUR_PASSWORD}}"
}

###############################################################################
# 1. CREATION (POST /api/categories)
###############################################################################

